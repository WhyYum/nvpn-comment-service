NODE_ENV=development
LOG_LEVEL=info

BOT_TOKEN=
ADMIN_IDS=123456789,987654321
ENCRYPTION_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ad_bot
REDIS_URL=redis://localhost:6379

PARSER_INTERVAL_SECONDS=300
STATUS_CHECK_INTERVAL_SECONDS=3600

# SOCKS-прокси для GramJS (MTProto). Docker Desktop proxy сюда не попадает — нужно явно.
# Локально (npm run dev): 127.0.0.1
# В контейнере app: host.docker.internal (прокси на Windows-хосте)
TELEGRAM_PROXY_ENABLED=false
TELEGRAM_PROXY_HOST=127.0.0.1
TELEGRAM_PROXY_PORT=2080
TELEGRAM_PROXY_TYPE=socks5

# Подробный JSON ответ Telegram в чате при добавлении аккаунта
AUTH_DEBUG=false
